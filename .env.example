# Set to "true" to enable the MSW mock API. Any other value (or unset)
# disables mocks and drops the MSW chunk from the build entirely.
VITE_ENABLE_MOCKS=true

# Origin the API is served from (e.g. https://api.example.com). Leave empty to
# use same-origin relative paths, which keeps MSW mocks and the nginx proxy working.
VITE_API_ORIGIN=
